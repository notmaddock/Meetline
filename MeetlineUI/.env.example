# --- General Server Config ---
NODE_ENV=development

# The base URL of the backend API
API_BASE_URL=http://localhost:8080

# The base URL of this frontend
APP_BASE_URL=http://localhost:3000

# --- Redis Config ---
# URL for the Redis server used for token storage
REDIS_URL=redis://localhost:6379

# --- Session Security ---
# 32+ character random strings for encrypting session cookies
# openssl rand -base64 32
COOKIE_SID_SECRET=
COOKIE_OAS_SECRET=

# --- Auth0 / OIDC Config ---
# Domain (e.g. tenant.us.auth0.com)
AUTH0_DOMAIN=

# Client ID
AUTH0_CLIENT_ID=

# Client secret
AUTH0_CLIENT_SECRET=

# The exact callback URL configured in Auth0 (e.g. http://localhost:3000/auth/callback)
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# The API audience configured in Auth0 (usually the backend API identifier/URL)
OIDC_AUDIENCE=

# --- Session & Token Behavior ---
# How long the Redis session lasts in seconds (e.g. 86400 for 24h)
# The TTL is rolled (reset) on every activity.
SESSION_ROLLING_TTL=86400

# Security entropy for generating random session IDs (min 16)
SESSION_ID_ENTROPY=32

# Number of seconds before token expiry to trigger a refresh (e.g. 30)
TOKEN_REFRESH_GRACE_PERIOD=30

# --- Client Side (Publicly Exposed) ---
# PostHog configuration for analytics
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
VITE_PUBLIC_POSTHOG_API_HOST=https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
